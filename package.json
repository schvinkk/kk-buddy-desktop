{
  "name": "kk-buddy-desktop",
  "version": "2.5.0",
  "description": "KK-Buddy - Universal AI Coding Assistant",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "first-run": "npm install --registry https://registry.npmmirror.com && electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "author": "Schvinkk",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.schvinkk.kk-buddy-desktop",
    "productName": "KK-Buddy",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.png",
      "icon.ico",
      "css/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KK-Buddy"
    }
  },
  "allowScripts": {
    "electron@35.7.5": true
  },
  "dependencies": {
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "pdfkit": "^0.19.1",
    "playwright": "^1.61.1",
    "pptxgenjs": "^4.0.1"
  }
}

